---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { getCollection } from "astro:content";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { Icon } from "astro-icon/components";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const FEATURED_TITLES = [
	"遥遥领先！基于《易经》中的中国哲学实现 Linux 进程调度",
	"Zh2Emoji：当 Transformer 遇见 Emoji",
	"基于 LangChain 实现的李立军老师演讲稿生成器",
];

const featuredPostsByTitle = posts.filter((post) =>
	FEATURED_TITLES.includes(post.data.title),
);
const featuredPosts =
	featuredPostsByTitle.length > 0 ? featuredPostsByTitle.slice(0, 3) : posts.slice(0, 3);

const featuredIds = new Set(featuredPosts.map((post) => post.id));
const recentUpdatedCandidates = posts
	.filter((post) => !featuredIds.has(post.id))
	.sort(
		(a, b) =>
			(b.data.updatedDate ?? b.data.pubDate).valueOf() -
			(a.data.updatedDate ?? a.data.pubDate).valueOf(),
	);
const recentUpdatedPosts =
	recentUpdatedCandidates.length > 0
		? recentUpdatedCandidates.slice(0, 5)
		: posts.slice(0, 5);
---

<!doctype html>
<html>
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			:global(body) { background-size: 100% 170px; }
			main {
				display: grid;
				gap: 2rem;
			}
			h1 {
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.intro {
				margin: 0;
			}
			.section-heading {
				margin-bottom: 0.75rem;
			}
			.section-description {
				margin: 0 0 1rem;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 0.75rem;
			}
			.post-item {
				padding: 0.9rem 1rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				background: rgb(var(--surface));
			}
			.post-title {
				margin: 0 0 0.35rem;
				font-size: 1.1rem;
				line-height: 1.3;
			}
			.post-title a {
				text-decoration: none;
			}
			.post-title a:hover {
				text-decoration: underline;
			}
			.post-meta {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.more-link {
				display: inline-block;
				margin-top: 0.9rem;
				font-weight: 700;
			}
			@media (max-width: 720px) {
				:global(body) { background-size: 100% 220px; }
				main {
					gap: 1.5rem;
				}
				.post-item {
					padding: 0.8rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1>
					你好<a
						href="/rss.xml"
						target="_blank"
						rel="noopener noreferrer"
					>
						<span class="sr-only">Subscribe via RSS</span>
						<Icon name="mdi:rss" size="32" aria-hidden="true" />
					</a>
				</h1>
				<p class="intro">
					这里是我的个人博客，欢迎来到我的世界！我叫
					Gujial，是一名热爱技术的开发者。在这里，我将分享我的编程经验、技术见解以及生活点滴。希望你能在这里找到有价值的内容，并与我一起探索技术的无限可能。
				</p>
			</section>

			<section aria-labelledby="featured-posts-heading">
				<h2 id="featured-posts-heading" class="section-heading">精选文章</h2>
				<p class="section-description">优先推荐给第一次来到这里的你。</p>
				<ul class="post-list">
					{
						featuredPosts.map((post) => (
							<li class="post-item">
								<h3 class="post-title">
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</h3>
								<p class="post-meta">
									发布于 <FormattedDate date={post.data.pubDate} />
								</p>
							</li>
						))
					}
				</ul>
			</section>

			<section aria-labelledby="recent-updated-posts-heading">
				<h2 id="recent-updated-posts-heading" class="section-heading">最近更新</h2>
				<p class="section-description">最近发布或维护更新的内容。</p>
				<ul class="post-list">
					{
						recentUpdatedPosts.map((post) => (
							<li class="post-item">
								<h3 class="post-title">
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</h3>
								<p class="post-meta">
									{post.data.updatedDate ? "更新于 " : "发布于 "}
									<FormattedDate date={post.data.updatedDate ?? post.data.pubDate} />
								</p>
							</li>
						))
					}
				</ul>
				<a class="more-link" href="/blog/">查看全部文章 →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
