---
import { Image } from "astro:assets";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const allTags = Array.from(
	new Set(posts.flatMap((post) => post.data.tags ?? [])),
).sort((a, b) => a.localeCompare(b, "zh-CN"));
---

<!doctype html>
<html>
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.toolbar {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 220px 220px;
				gap: 0.75rem;
				align-items: center;
				margin-bottom: 1.25rem;
				padding: 0.5rem;
				border-radius: 12px;
				background: color-mix(in srgb, var(--accent) 10%, rgb(var(--surface)));
			}
			.search-input,
			.sort-select,
			.tag-select {
				width: 100%;
				padding: 0.55rem 0.7rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 10px;
				background: rgb(var(--surface));
				color: rgb(var(--gray-dark));
				font: inherit;
				font-size: 0.95rem;
			}
			.search-input::placeholder {
				color: rgb(var(--gray));
			}
			.search-input:focus,
			.sort-select:focus,
			.tag-select:focus {
				outline: 2px solid color-mix(in srgb, var(--accent) 35%, transparent);
				outline-offset: 1px;
				border-color: var(--accent);
			}
			ul {
				display: grid;
				gap: 1.25rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: 100%;
				padding-bottom: 1.25rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			ul li:last-child {
				padding-bottom: 0;
				border-bottom: none;
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			.post-image {
				width: 100%;
				height: 100%;
				max-width: 280px;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				border-radius: 12px;
			}
			.post-link {
				display: grid;
				grid-template-columns: minmax(220px, 280px) minmax(0, 1fr);
				gap: 1.25rem;
				align-items: center;
				color: inherit;
			}
			.post-link > div {
				display: grid;
				gap: 0.45rem;
				align-content: center;
			}
			.text-link {
				display: grid;
				gap: 0.35rem;
				color: inherit;
				text-decoration: none;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.35rem;
				margin-top: 0.2rem;
			}
			.tag-chip {
				display: inline-flex;
				align-items: center;
				padding: 0.1rem 0.5rem;
				border-radius: 999px;
				border: 1px solid rgb(var(--gray-light));
				background: rgb(var(--surface));
				color: rgb(var(--gray));
				font-size: 0.78rem;
				line-height: 1.2;
				text-decoration: none;
			}
			.tag-chip:hover {
				color: var(--accent);
				border-color: color-mix(in srgb, var(--accent) 40%, rgb(var(--gray-light)));
				background: color-mix(in srgb, var(--accent) 10%, rgb(var(--surface)));
			}
			.post-link:hover .title,
			.post-link:hover .date {
				color: var(--accent);
			}
			.post-link:hover .post-image {
				box-shadow: var(--box-shadow);
			}
			.list-meta {
				margin: 0 0 0.75rem;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.empty-state {
				margin: 0;
				padding: 0.75rem 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.pagination {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				justify-content: center;
				align-items: center;
				margin-top: 1.25rem;
			}
			.pagination button {
				border: 1px solid rgb(var(--gray-light));
				background: #fff;
				color: rgb(var(--gray-dark));
				padding: 0.35rem 0.65rem;
				border-radius: 999px;
				cursor: pointer;
				font: inherit;
				font-size: 0.9rem;
				line-height: 1.2;
			}
			.pagination button[disabled] {
				opacity: 0.45;
				cursor: not-allowed;
			}
			.pagination button[aria-current="page"] {
				background: var(--accent);
				border-color: var(--accent);
				color: #fff;
			}
			@media (max-width: 720px) {
				.toolbar {
					grid-template-columns: 1fr;
				}
				ul {
					gap: 1rem;
				}
				ul li {
					width: 100%;
					padding-bottom: 1rem;
				}
				.post-link {
					grid-template-columns: 1fr;
					gap: 0.75rem;
				}
				.post-image {
					max-width: none;
				}
				.post-link > div {
					gap: 0.25rem;
				}
				.text-link {
					gap: 0.25rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="toolbar">
					<input
						type="search"
						class="search-input"
						placeholder="搜索标题..."
						aria-label="搜索文章标题"
						data-search
					/>
					<select class="sort-select" aria-label="按时间排序" data-sort>
						<option value="desc">时间倒序（最新优先）</option>
						<option value="asc">时间正序（最早优先）</option>
					</select>
					<select class="tag-select" aria-label="按标签筛选" data-tag>
						<option value="all">全部标签</option>
						{
							allTags.map((tag) => (
								<option value={tag.toLowerCase()}>{tag}</option>
							))
						}
					</select>
				</div>
				<p class="list-meta" data-meta></p>
				<p class="empty-state" data-empty hidden>没有找到符合条件的文章。</p>
				<ul data-post-list>
					{
						posts.map((post) => (
							<li
								data-post-item
								data-title={post.data.title.toLowerCase()}
								data-pub-date={post.data.pubDate.valueOf()}
								data-tags={(post.data.tags ?? []).map((tag) => tag.toLowerCase()).join("|")}
							>
								<div class="post-link">
									<a href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<Image
												class="post-image"
												src={post.data.heroImage}
												alt=""
												width={280}
												height={158}
											/>
										)}
									</a>
									<div>
										<a class="text-link" href={`/blog/${post.id}/`}>
											<h4 class="title">{post.data.title}</h4>
											<p class="date">
												<FormattedDate
													date={post.data.pubDate}
												/>
											</p>
										</a>
										{
											post.data.tags.length > 0 && (
												<div class="tags" aria-label="文章标签">
													{post.data.tags.map((tag) => (
														<a
															class="tag-chip"
															href={`/tags/${encodeURIComponent(tag.toLowerCase())}/`}
														>
															#{tag}
														</a>
													))}
												</div>
											)
										}
									</div>
								</div>
							</li>
						))
					}
				</ul>
				<nav class="pagination" aria-label="博客分页" data-pagination></nav>
			</section>
		</main>
		<Footer />
		<script>
			const PAGE_SIZE = 10;
			const list = document.querySelector("[data-post-list]") as HTMLUListElement | null;
			const searchInput = document.querySelector("[data-search]") as HTMLInputElement | null;
			const sortSelect = document.querySelector("[data-sort]") as HTMLSelectElement | null;
			const tagSelect = document.querySelector("[data-tag]") as HTMLSelectElement | null;
			const meta = document.querySelector("[data-meta]") as HTMLParagraphElement | null;
			const empty = document.querySelector("[data-empty]") as HTMLParagraphElement | null;
			const pagination = document.querySelector("[data-pagination]") as HTMLElement | null;
			const items: HTMLElement[] = list
				? Array.from(list.querySelectorAll<HTMLElement>("[data-post-item]"))
				: [];

			const state = {
				query: "",
				sort: "desc" as "asc" | "desc",
				tag: "all",
				page: 1,
			};

			const compareByDate = (a: HTMLElement, b: HTMLElement, direction: "asc" | "desc") => {
				const aDate = Number(a.dataset.pubDate || 0);
				const bDate = Number(b.dataset.pubDate || 0);
				return direction === "asc" ? aDate - bDate : bDate - aDate;
			};

			const getFilteredAndSorted = () => {
				const query = state.query.trim().toLowerCase();
				const filtered = items.filter((item) => {
					const matchesTitle = (item.dataset.title || "").includes(query);
					const tags = (item.dataset.tags || "").split("|").filter(Boolean);
					const matchesTag = state.tag === "all" || tags.includes(state.tag);
					return matchesTitle && matchesTag;
				});
				return filtered.sort((a, b) => compareByDate(a, b, state.sort));
			};

			const renderPagination = (totalPages: number) => {
				if (!pagination) return;
				pagination.innerHTML = "";

				const createButton = (
					label: string,
					page: number,
					disabled = false,
					isCurrent = false,
				) => {
					const button = document.createElement("button");
					button.type = "button";
					button.textContent = label;
					button.disabled = disabled;
					if (isCurrent) {
						button.setAttribute("aria-current", "page");
					}
					button.addEventListener("click", () => {
						state.page = page;
						render();
					});
					return button;
				};

				pagination.appendChild(
					createButton("上一页", state.page - 1, state.page <= 1),
				);

				for (let page = 1; page <= totalPages; page += 1) {
					pagination.appendChild(
						createButton(String(page), page, false, page === state.page),
					);
				}

				pagination.appendChild(
					createButton("下一页", state.page + 1, state.page >= totalPages),
				);
			};

			const render = () => {
				const filtered = getFilteredAndSorted();
				const total = filtered.length;
				const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
				state.page = Math.min(state.page, totalPages);

				const start = (state.page - 1) * PAGE_SIZE;
				const end = start + PAGE_SIZE;
				const pageItems = filtered.slice(start, end);
				const pageSet = new Set(pageItems);

				if (list) {
					const hiddenItems = items.filter((item) => !filtered.includes(item));
					for (const item of [...pageItems, ...hiddenItems]) {
						list.appendChild(item);
					}
				}

				items.forEach((item) => {
					item.hidden = !pageSet.has(item);
				});

				if (meta) {
					meta.textContent = `共 ${total} 篇，当前第 ${state.page} / ${totalPages} 页，每页 ${PAGE_SIZE} 篇`;
				}

				if (empty) {
					empty.hidden = total !== 0;
				}

				renderPagination(totalPages);
			};

			searchInput?.addEventListener("input", (event: Event) => {
				if (!(event.currentTarget instanceof HTMLInputElement)) return;
				const target = event.currentTarget;
				state.query = target.value;
				state.page = 1;
				render();
			});

			sortSelect?.addEventListener("change", (event: Event) => {
				if (!(event.currentTarget instanceof HTMLSelectElement)) return;
				const target = event.currentTarget;
				state.sort = target.value === "asc" ? "asc" : "desc";
				state.page = 1;
				render();
			});

			tagSelect?.addEventListener("change", (event: Event) => {
				if (!(event.currentTarget instanceof HTMLSelectElement)) return;
				const target = event.currentTarget;
				state.tag = target.value;
				state.page = 1;
				render();
			});

			render();
		</script>
	</body>
</html>
