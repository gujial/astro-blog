---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = Omit<CollectionEntry<"blog">["data"], "heroImage" | "tags"> & {
	heroImage?: ImageMetadata;
	tags?: string[];
};

const { title, description, pubDate, updatedDate, heroImage, tags = [] } =
	Astro.props as Props;
---

<html>
	<head>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/katex@0.16.15/dist/katex.min.css"
			integrity="sha384-Htz9HMhiwV8GuQ28Xr9pEs1B4qJiYu/nYLLwlDklR53QibDfmQzi7rYxXhMH/5/u"
			crossorigin="anonymous"
		/>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image__image {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				width: 100%;
				max-width: 1020px;
				max-height: 510px;
				object-fit: cover;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				justify-content: center;
				margin: 0.2rem 0 1rem;
			}
			.tag-chip {
				display: inline-flex;
				align-items: center;
				padding: 0.22rem 0.7rem;
				border-radius: 999px;
				border: 1px solid rgb(var(--gray-light));
				background: rgb(var(--surface));
				color: rgb(var(--gray));
				font-size: 0.82rem;
				line-height: 1.2;
				text-decoration: none;
				transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
			}
			.tag-chip:hover {
				color: var(--accent);
				border-color: color-mix(in srgb, var(--accent) 45%, rgb(var(--gray-light)));
				background: color-mix(in srgb, var(--accent) 10%, rgb(var(--surface)));
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{
						heroImage && (
							<Image
								class="hero-image__image"
								src={heroImage}
								alt=""
								width={1020}
								height={510}
							/>
						)
					}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on{" "}
										<FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{
							tags.length > 0 && (
								<div class="tags" aria-label="文章标签">
									{tags.map((tag) => (
										<a class="tag-chip" href={`/tags/${encodeURIComponent(tag.toLowerCase())}/`}>
											#{tag}
										</a>
									))}
								</div>
							)
						}
						<hr />
					</div>
					<slot />
				</div>
			</article>
			<div class="prose">
				<script
				src="https://giscus.app/client.js"
				data-repo="gujial/astro-blog"
				data-repo-id="R_kgDOTVv5EQ"
				data-category="Announcements"
				data-category-id="DIC_kwDOTVv5Ec4DBJwv"
				data-mapping="pathname"
				data-strict="0"
				data-reactions-enabled="1"
				data-emit-metadata="0"
				data-input-position="bottom"
				data-theme="preferred_color_scheme"
				data-lang="zh-CN"
				data-loading="lazy"
				crossorigin="anonymous"
				async
			></script>
			</div>
		</main>
		<Footer />
	</body>
</html>
