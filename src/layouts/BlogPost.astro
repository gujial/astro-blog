---
import type { ImageMetadata } from "astro";
import type { MarkdownHeading } from "astro";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = Omit<CollectionEntry<"blog">["data"], "heroImage" | "tags"> & {
	heroImage?: ImageMetadata;
	tags?: string[];
	headings?: MarkdownHeading[];
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
	headings = [],
} = Astro.props as Props;

const tocHeadings = headings.filter(
	(heading) => heading.depth >= 2 && heading.depth <= 3,
);
---

<html>
	<head>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/katex@0.16.15/dist/katex.min.css"
			integrity="sha384-Htz9HMhiwV8GuQ28Xr9pEs1B4qJiYu/nYLLwlDklR53QibDfmQzi7rYxXhMH/5/u"
			crossorigin="anonymous"
		/>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image__image {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				width: 100%;
				max-width: 1020px;
				max-height: 510px;
				object-fit: cover;
			}
			.prose {
				width: 100%;
				margin: 0;
				padding: 0;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				justify-content: center;
				margin: 0.2rem 0 1rem;
			}
			.tag-chip {
				display: inline-flex;
				align-items: center;
				padding: 0.22rem 0.7rem;
				border-radius: 999px;
				border: 1px solid rgb(var(--gray-light));
				background: rgb(var(--surface));
				color: rgb(var(--gray));
				font-size: 0.82rem;
				line-height: 1.2;
				text-decoration: none;
				transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
			}
			.tag-chip:hover {
				color: var(--accent);
				border-color: color-mix(in srgb, var(--accent) 45%, rgb(var(--gray-light)));
				background: color-mix(in srgb, var(--accent) 10%, rgb(var(--surface)));
			}
			.post-shell {
				position: relative;
				display: block;
			}
			.post-shell__article {
				width: 900px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
			}
			.toc {
				position: fixed;
				top: 6.5rem;
				right: 1rem;
				width: min(18rem, calc(100vw - 2rem));
				max-width: calc(100vw - 2rem);
				padding: 1rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 16px;
				background: rgba(var(--surface), 0.96);
				box-shadow: var(--box-shadow);
				z-index: 20;
				backdrop-filter: blur(10px);
			}
			.toc--collapsed .toc__nav {
				display: none;
			}
			.toc--collapsed {
				width: max-content;
				max-width: max-content;
				padding: 0;
				border: 0;
				background: transparent;
				box-shadow: none;
				backdrop-filter: none;
				-webkit-backdrop-filter: none;
			}
			.toc__header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.75rem;
				margin-bottom: 0.75rem;
			}
			.toc--collapsed .toc__header {
				margin-bottom: 0;
				justify-content: center;
			}
			.toc--collapsed .toc__title {
				display: none;
			}
			.toc__title {
				margin: 0;
				font-size: 0.9rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: rgb(var(--gray));
				text-align: left;
			}
			.toc__toggle {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				background: rgb(var(--surface));
				color: rgb(var(--gray-dark));
				padding: 0.3rem 0.7rem;
				font: inherit;
				font-size: 0.82rem;
				line-height: 1;
				cursor: pointer;
			}
			.toc__toggle:hover {
				color: var(--accent);
				border-color: color-mix(in srgb, var(--accent) 45%, rgb(var(--gray-light)));
			}
			.toc--collapsed .toc__toggle {
				min-width: 2.75rem;
				padding-inline: 0.55rem;
				background: rgba(var(--surface), 0.96);
				box-shadow: var(--box-shadow);
			}
			.toc__nav {
				text-align: left;
			}
			.toc ol {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 0.45rem;
			}
			.toc li {
				margin: 0;
			}
			.toc-link {
				display: block;
				color: rgb(var(--gray-dark));
				text-decoration: none;
				line-height: 1.4;
				text-align: left;
			}
			.toc-link:hover {
				color: var(--accent);
			}
			.toc-link--depth-3 {
				padding-left: 0.9rem;
				font-size: 0.94rem;
			}
			@media (max-width: 900px) {
				.toc {
					top: 5.5rem;
					right: 0.75rem;
					width: min(16.5rem, calc(100vw - 1.5rem));
					max-width: calc(100vw - 1.5rem);
				}
			}
			@media (max-width: 900px) {
				.toc {
					top: auto;
					bottom: calc(env(safe-area-inset-bottom, 0px) + 0.75rem);
					right: 0.75rem;
					left: auto;
					width: auto;
					max-width: calc(100vw - 1.5rem);
					backdrop-filter: none;
					-webkit-backdrop-filter: none;
				}
				.toc--collapsed {
					left: auto;
					right: 0.75rem;
					width: max-content;
					max-width: max-content;
				}
				.toc:not(.toc--collapsed) {
					width: min(16.5rem, calc(100vw - 1.5rem));
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<div class="post-shell">
				<article class="post-shell__article">
					<div class="hero-image">
					{
						heroImage && (
							<Image
								class="hero-image__image"
								src={heroImage}
								alt=""
								width={1020}
								height={510}
							/>
						)
					}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on{" "}
										<FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{
							tags.length > 0 && (
								<div class="tags" aria-label="文章标签">
									{tags.map((tag) => (
										<a class="tag-chip" href={`/tags/${encodeURIComponent(tag.toLowerCase())}/`}>
											#{tag}
										</a>
									))}
								</div>
							)
						}
						<hr />
					</div>
					<slot />
					</div>
				</article>
				{
					tocHeadings.length > 0 && (
						<aside class="toc" aria-label="文章目录" data-toc>
							<div class="toc__header">
								<p class="toc__title">目录</p>
								<button class="toc__toggle" type="button" aria-expanded="true" aria-controls="toc-list" data-toc-toggle>
									收回
								</button>
							</div>
							<nav class="toc__nav" id="toc-list" data-toc-nav>
								<ol>
									{tocHeadings.map((heading) => (
										<li>
											<a class={`toc-link toc-link--depth-${heading.depth}`} href={`#${heading.slug}`}>
												{heading.text}
											</a>
										</li>
									))}
								</ol>
							</nav>
						</aside>
					)
				}
			</div>
			<div class="prose">
				<script
				src="https://giscus.app/client.js"
				data-repo="gujial/astro-blog"
				data-repo-id="R_kgDOTVv5EQ"
				data-category="Announcements"
				data-category-id="DIC_kwDOTVv5Ec4DBJwv"
				data-mapping="pathname"
				data-strict="0"
				data-reactions-enabled="1"
				data-emit-metadata="0"
				data-input-position="bottom"
				data-theme="preferred_color_scheme"
				data-lang="zh-CN"
				data-loading="lazy"
				crossorigin="anonymous"
				async
			></script>
			</div>
			<script>
				const toc = document.querySelector("[data-toc]");
				const toggle = document.querySelector("[data-toc-toggle]");
				const nav = document.querySelector("[data-toc-nav]");
				const storageKey = "astro-blog-toc-collapsed";

				if (toc instanceof HTMLElement && toggle instanceof HTMLButtonElement && nav instanceof HTMLElement) {
					const applyState = (collapsed: boolean) => {
						toc.classList.toggle("toc--collapsed", collapsed);
						toggle.setAttribute("aria-expanded", String(!collapsed));
						toggle.textContent = collapsed ? "目录" : "收回";
						nav.hidden = collapsed;
					};

					const savedState = window.localStorage.getItem(storageKey);
					applyState(savedState === null ? true : savedState === "1");

					toggle.addEventListener("click", () => {
						const collapsed = !toc.classList.contains("toc--collapsed");
						applyState(collapsed);
						window.localStorage.setItem(storageKey, collapsed ? "1" : "0");
					});
				}
			</script>
		</main>
		<Footer />
	</body>
</html>
